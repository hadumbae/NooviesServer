{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/shared/*"],
      "@shared/*": ["./src/shared/*"],
      "@domains/*": ["./src/domains/*"],

      "@config/*": ["./src/shared/config/*"],
      "@models/*": ["./src/domains/users/model/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "module": "NodeNext",
    "moduleResolution": "Bundler",
    "outDir": "dist"
  }
}